# ── Supabase ─────────────────────────────────────────────────────────────────
# Get these from: https://supabase.com/dashboard → your project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Site URL (used for auth redirects) ───────────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Optional: Jitsi self-hosted server ───────────────────────────────────────
# If left blank, the public meet.jit.si server is used (fine for development).
# For production, deploy your own Jitsi instance and set this:
# NEXT_PUBLIC_JITSI_HOST=jitsi.your-domain.com
